# ─────────────────────────────────────────────
# データベース
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://meishi_user:meishi_password@localhost:5432/meishi_db"

# ─────────────────────────────────────────────
# 認証（JWT）
# openssl rand -base64 32 で生成すること
# ─────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ─────────────────────────────────────────────
# アプリURL
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Google Cloud Vision API
# https://console.cloud.google.com/ で取得
# ─────────────────────────────────────────────
GOOGLE_VISION_API_KEY="your-google-vision-api-key-here"

# ─────────────────────────────────────────────
# ファイルアップロード先（ローカル）
# 本番では S3_* に切り替え
# ─────────────────────────────────────────────
UPLOAD_DIR="./uploads"

# ─────────────────────────────────────────────
# S3互換ストレージ（本番用・任意）
# ─────────────────────────────────────────────
# S3_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_BUCKET_NAME="meishi-uploads"
# S3_PUBLIC_URL="https://your-public-domain.com"
